# ============================================================
# Institutional Crypto Futures Intelligence Platform — .env
# Copy to `.env` and edit. NEVER commit real secrets.
# ============================================================

# ----- Runtime -----
ENVIRONMENT=development
LOG_LEVEL=INFO
LOG_FORMAT=json
OFFLINE_MODE=false

# ----- Database (PostgreSQL) -----
DATABASE_URL=postgresql+asyncpg://platform:platform@localhost:5432/platform
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10
DB_ECHO=false

# ----- Redis -----
REDIS_URL=redis://localhost:6379/0
REDIS_NAMESPACE=platform

# ----- Binance Futures -----
BINANCE_TESTNET=true
# Leave blank to auto-derive from testnet flag:
# BINANCE_REST_URL=https://testnet.binancefuture.com/fapi
# BINANCE_WS_URL=wss://stream.binancefuture.com
BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_RECV_WINDOW_MS=5000
BINANCE_REQUEST_TIMEOUT=10.0
BINANCE_WEIGHT_PER_MINUTE=2400

# WebSocket
BINANCE_WS_RECONNECT_DELAY=1.0
BINANCE_WS_RECONNECT_MAX_DELAY=60.0
BINANCE_WS_HEARTBEAT_SEC=30
BINANCE_WS_MAX_STREAMS_PER_CONN=200

# ----- AI providers -----
AI_PROVIDER_ORDER=nim,openrouter,mock
AI_DEFAULT_MODEL=meta/llama-3.1-70b-instruct

# NVIDIA NIM
NIM_BASE_URL=https://integrate.api.nvidia.com/v1
NIM_API_KEY=
NIM_MODEL=meta/llama-3.1-70b-instruct
NIM_TIMEOUT=30.0

# OpenRouter
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.1-70b-instruct
OPENROUTER_TIMEOUT=30.0

# AI behaviour
AI_MAX_REQUESTS_PER_CYCLE=10
AI_CONCURRENCY=3
AI_CACHE_TTL_SEC=300
AI_TEMPERATURE=0.2
AI_MAX_TOKENS=800
AI_SKIP_IF_CONFLUENCE_BELOW=75
AI_SKIP_IF_RR_BELOW=2.0

# ----- Telegram -----
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_ENABLED=false
TELEGRAM_DEDUP_WINDOW_SEC=600
TELEGRAM_THROTTLE_PER_MIN=20

# ----- Scanning -----
SCAN_INTERVAL_SEC=60
SCAN_MAX_PAIRS=500
SCAN_STAGE1_TOP_N=30
SCAN_STAGE2_TOP_N=5
SCAN_TIMEFRAMES=1h,15m,5m
SCAN_TARGET_SCAN_DURATION_SEC=5.0

STAGE1_MIN_CONFLUENCE=50
STAGE1_MIN_ATR_PCT=0.5
STAGE1_MIN_VOLUME_USD=5000000

STAGE2_MIN_CONFLUENCE=70
STAGE2_MIN_RR=2.0

STAGE3_MIN_CONFLUENCE=75
STAGE3_MIN_RR=2.0

# ----- Risk management -----
RISK_ACCOUNT_BALANCE=10000
RISK_MAX_RISK_PER_TRADE_PCT=1.0
RISK_INTRADAY_SL_MAX_PCT=3.0
RISK_SWING_SL_MAX_PCT=5.0
RISK_MIN_RR=2.0
RISK_ATR_MULTIPLIER_SL=1.5
RISK_ATR_MULTIPLIER_TP=3.0
RISK_MAX_OPEN_POSITIONS=5

# ----- Confluence weights (must sum to 100) -----
CONFLUENCE_WEIGHT_MARKET_STRUCTURE=20
CONFLUENCE_WEIGHT_TREND=18
CONFLUENCE_WEIGHT_LIQUIDITY=15
CONFLUENCE_WEIGHT_SMART_MONEY=15
CONFLUENCE_WEIGHT_EMA=8
CONFLUENCE_WEIGHT_VOLUME=6
CONFLUENCE_WEIGHT_PRESSURE=5
CONFLUENCE_WEIGHT_OPEN_INTEREST=4
CONFLUENCE_WEIGHT_FUNDING=3
CONFLUENCE_WEIGHT_VWAP=2
CONFLUENCE_WEIGHT_ATR=1
CONFLUENCE_WEIGHT_ADX=1
CONFLUENCE_WEIGHT_BOLLINGER=1
CONFLUENCE_WEIGHT_SUPPORT_RESISTANCE=1
CONFLUENCE_WEIGHT_RSI=0

# ----- Retention (days) -----
RETENTION_MARKET_DATA_DAYS=30
RETENTION_SIGNALS_DAYS=365
RETENTION_AI_DECISIONS_DAYS=90
RETENTION_LOGS_DAYS=30
RETENTION_METRICS_DAYS=30

# ----- API -----
API_HOST=0.0.0.0
API_PORT=8080
API_WORKERS=1
